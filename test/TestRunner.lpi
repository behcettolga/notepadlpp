<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="NotepadL++ TestRunner"/>
    </General>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="encconv_package"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="TestRunner.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="uTestSmoke.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestSmoke"/>
      </Unit>
      <Unit>
        <Filename Value="uTestEncoding.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestEncoding"/>
      </Unit>
      <Unit>
        <Filename Value="uTestFileIO.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestFileIO"/>
      </Unit>
      <Unit>
        <Filename Value="uTestDocument.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestDocument"/>
      </Unit>
      <Unit>
        <Filename Value="uTestSearch.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestSearch"/>
      </Unit>
      <Unit>
        <Filename Value="uTestFindInFiles.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestFindInFiles"/>
      </Unit>
      <Unit>
        <Filename Value="uTestEditorActions.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestEditorActions"/>
      </Unit>
      <Unit>
        <Filename Value="uTestConverters.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestConverters"/>
      </Unit>
      <Unit>
        <Filename Value="uTestTools.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTestTools"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="TestRunner"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="../src/core;../src/search;../src/tools;../src/editor"/>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Parsing>
      <SyntaxOptions>
        <UseAnsiStrings Value="True"/>
      </SyntaxOptions>
    </Parsing>
    <Linking>
      <Options>
        <Win32>
          <GraphicApplication Value="False"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
</CONFIG>
